# Base default environment
# Settings module to use
DJANGO_SETTINGS_MODULE='sopds.settings.base'

# Run in debug mode
DEBUG=False

# Sopds-ng version
VERSION_FILE='version.txt'

# Common root directory for all configuration and persistent data
DATA_ROOT=/data

# Django secret key
SECRET_KEY_FILE=/data/secret_key.txt

# Server log level
SOPDS_SERVER_LOG_LEVEL='WARNING'

# Django database settings
# Default: PostgreSQL (требуется сервер PostgreSQL)
SOPDS_DB_ENGINE='postgres'
SOPDS_DB_NAME=''
SOPDS_DB_USER=''
SOPDS_DB_PASSWORD=''
SOPDS_DB_HOST=''
SOPDS_DB_PORT=''
# Для SQLite (bare-metal, без отдельного сервера):
#   SOPDS_DB_ENGINE='sqlite'
# Для MySQL/MariaDB:
#   SOPDS_DB_ENGINE='mysql'
#   SOPDS_DB_NAME='sopds'
#   SOPDS_DB_USER='root'
#   SOPDS_DB_PASSWORD=''
#   SOPDS_DB_HOST='localhost'
#   SOPDS_DB_PORT='3306'

# Server time zone
TIME_ZONE='Europe/Moscow'

# Path to books directory for Docker deployment
# SOPDS_BOOK_PATH='/books'

# Allowed hosts for production (comma-separated)
# ALLOWED_HOSTS='localhost,127.0.0.1'
